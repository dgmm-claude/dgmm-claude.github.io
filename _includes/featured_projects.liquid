{%- comment -%}
  ============================================================================
  featured_projects.liquid — "Selected Projects" index for the About page.
  ----------------------------------------------------------------------------
  Renders compact cards for projects flagged `featured_on_about: true`, ordered
  by the stable `importance` field (NOT filename), capped at `include.limit`
  (default 3). Each card shows the cover image, the CURRENT-LANGUAGE title &
  abstract (swapped by i18n.js), an availability badge, and links to the detail
  page. It does NOT duplicate the project body.
  ============================================================================
{%- endcomment -%}
{%- assign fp_limit = include.limit | default: 3 | times: 1 -%}
{%- assign featured = site.projects | where: 'featured_on_about', true | sort: 'importance' -%}
<div class="featured-projects">
  <style>
    /* Keep featured card covers at a uniform 16:9 like the Projects page. */
    .featured-projects .card-img-top {
      width: 100% !important;
      aspect-ratio: 16 / 9;
      object-fit: cover;
      background-color: #f2f2f2;
    }
  </style>
  <h2>
    <span data-zh-text="精选项目" data-en-text="Selected Projects">Selected Projects</span>
  </h2>
  <div class="row row-cols-1 row-cols-md-3">
    {%- for project in featured limit: fp_limit -%}
    <div class="col mb-4">
      <a href="{{ project.url | relative_url }}">
        <div class="card h-100 hoverable">
          {% if project.img %}
            {% include figure.liquid loading="eager" path=project.img sizes="250px" alt="project thumbnail" class="card-img-top" %}
          {% endif %}
          <div class="card-body">
            <h3 class="card-title" data-zh-text="{{ project.title_zh | default: project.title }}" data-en-text="{{ project.title }}">{{ project.title }}</h3>
            <p class="card-text" data-zh-text="{{ project.description_zh | default: project.description }}" data-en-text="{{ project.description }}">{{ project.description }}</p>
            {% include lang_badge.liquid has_zh=project.has_zh_content has_en=project.has_en_content %}
          </div>
        </div>
      </a>
    </div>
    {%- endfor -%}
  </div>
</div>
